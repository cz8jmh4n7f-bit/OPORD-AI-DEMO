# Copy to .env and fill in. .env is gitignored - never commit real secrets.
# NOTE: `docker compose -f deployments/ai-compose.yml up` needs NO .env at all;
# these variables matter only if you run the api/worker from source.

# --- Core ---
DATABASE_URL=postgres://opord:opord@localhost:5432/opord?sslmode=disable
OPORD_HTTP_ADDR=:8080
OPORD_LOG_LEVEL=info

# --- Multi-user API-key auth (off = single-team dev mode) ---
OPORD_AUTH_ENABLED=false

# --- AI provider keys (Option B - quick env path; prefer the secret store) ---
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=

# --- Secret store (Option A - OpenBao/Vault KV v2; used when secret_ref is set) ---
#VAULT_ADDR=http://localhost:8200
#VAULT_TOKEN=
#VAULT_KV_MOUNT=secret

# --- Host ports published by deployments/ai-compose.yml ---
#OPORD_API_PORT=8080
#OPORD_WEB_PORT=3000
