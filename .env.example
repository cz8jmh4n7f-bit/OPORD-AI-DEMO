# Copy to .env and fill in. .env is gitignored. Never commit real secrets.

# --- OPORD API / Worker ---
OPORD_HTTP_ADDR=:8080
OPORD_LOG_LEVEL=info
OPORD_ENV=dev

# --- PostgreSQL (app data + Tofu pg state backend) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=opord
POSTGRES_PASSWORD=opord
POSTGRES_DB=opord
# Full DSN used by pgx, goose, sqlc, and the Tofu `pg` backend.
DATABASE_URL=postgres://opord:opord@localhost:5432/opord?sslmode=disable

# --- HashiCorp Vault (dev) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=opord-dev-root-token
# KV v2 mount + base path where provider credentials live.
VAULT_KV_MOUNT=secret
VAULT_KV_BASE=opord

# --- Authentik OIDC ---
OIDC_ISSUER_URL=http://localhost:9000/application/o/opord/
OIDC_CLIENT_ID=opord
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback

# --- Authentik bootstrap (docker-compose) ---
AUTHENTIK_SECRET_KEY=change-me-generate-a-50-char-random-string
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me
AUTHENTIK_BOOTSTRAP_TOKEN=change-me
AUTHENTIK_PG_PASSWORD=authentik

# --- OpenTofu / provider runtime ---
# Directory holding the wrapped Tofu modules (see modules/).
OPORD_MODULES_DIR=./modules
# Path to the tofu binary (defaults to "tofu" on PATH).
TOFU_BIN=tofu

# --- Ansible runtime ---
ANSIBLE_DIR=./ansible
# SSH private key used to reach freshly provisioned VMs.
OPORD_SSH_PRIVATE_KEY=~/.ssh/id_ed25519
